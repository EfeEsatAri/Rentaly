@model IEnumerable<ResultBrandDto>

@{
    ViewData["Title"] = "Marka Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}


<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Marka Yönetimi</h2>
        <a asp-action="CreateBrand" class="btn btn-primary">
            <i class="fas fa-plus"></i> Yeni Marka Ekle
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 10%">ID</th>
                        <th style="width: 15%">Logo</th>
                        <th>Marka Adı</th>
                        <th style="width: 20%" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.BrandId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.BrandName"
                                         style="width: 50px; height: 50px; object-fit: contain;"
                                         class="rounded border" />
                                }
                                else
                                {
                                    <span class="text-muted">Görsel Yok</span>
                                }
                            </td>
                            <td class="fw-bold">@item.BrandName</td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a asp-action="UpdateBrand" asp-route-id="@item.BrandId"
                                       class="btn btn-outline-warning btn-sm">
                                        <i class="fas fa-edit"></i> Güncelle
                                    </a>
                                    <a asp-action="DeleteBrand" asp-route-id="@item.BrandId"
                                       class="btn btn-outline-danger btn-sm"
                                       onclick="return confirm('@item.BrandName markasını silmek istediğinize emin misiniz?')">
                                        <i class="fas fa-trash"></i> Sil
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

