@model List<ResultFooterDto>
@{
    ViewData["Title"] = "Footer Bilgileri";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-shoe-prints me-2"></i>Alt Bilgi (Footer) Yönetimi</h5>
            <a href="/Footer/CreateFooter/" class="btn btn-outline-light btn-sm">
                <i class="fas fa-plus me-1"></i>Yeni Footer Alanı
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Hakkımızda Özeti</th>
                            <th>İletişim Bilgileri</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td>
                                    <p class="text-muted small mb-0" style="max-width: 300px;">@item.About</p>
                                </td>
                                <td>
                                    <div class="small">
                                        <i class="fas fa-phone text-success me-2"></i>@item.Phone <br />
                                        <i class="fas fa-envelope text-primary me-2"></i>@item.Email <br />
                                        <i class="fas fa-map-marker-alt text-danger me-2"></i>@item.Location
                                    </div>
                                </td>
                                <td class="text-center">
                                    <a href="/Footer/UpdateFooter/@item.FooterId" class="btn btn-sm btn-info text-white" title="Düzenle">
                                        <i class="fas fa-edit"></i> Düzenle
                                    </a>
                                    <a href="/Footer/DeleteFooter/@item.FooterId" class="btn btn-sm btn-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>