@model CreateFooterDto
@{
    ViewData["Title"] = "Yeni Footer";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm mx-auto" style="max-width: 900px;">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Yeni Alt Bilgi Tanımla</h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase small">Hakkımızda Yazısı</label>
                    <textarea asp-for="About" rows="4" class="form-control" placeholder="Footer'da görünecek kısa şirket tanıtımı..."></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-uppercase small">Telefon</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-phone"></i></span>
                            <input type="text" asp-for="Phone" class="form-control" placeholder="+90 ..." />
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-uppercase small">E-Posta</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                            <input type="email" asp-for="Email" class="form-control" placeholder="info@kurum.com" />
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-uppercase small">Adres / Konum</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-map-marked-alt"></i></span>
                        <input type="text" asp-for="Location" class="form-control" placeholder="Şehir, İlçe, Cadde..." />
                    </div>
                </div>

                <div class="text-end border-top pt-3">
                    <a href="/Footer/FooterList" class="btn btn-light border px-4">Listeye Dön</a>
                    <button type="submit" class="btn btn-primary px-5 shadow">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>