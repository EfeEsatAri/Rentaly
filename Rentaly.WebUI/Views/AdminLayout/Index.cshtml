    <link rel="stylesheet" href="/css/style.css" />
</head>
@await RenderSectionAsync("Styles",required: false)
<body>

    <aside class="sidebar" id="sidebar">
        <a href="/Admin/Dashboard/Index" class="sidebar-logo">
            <div class="logo-icon">
                <img src="~/efe foto.jpeg" alt="Efe Esat Arı" class="sidebar-profile-img">
