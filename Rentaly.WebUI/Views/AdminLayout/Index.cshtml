    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<style>
    /* Logo alanındaki ikon kutusunu düzenliyoruz */
    .logo-icon {
        width: 45px; /* Kutunun genişliği */
        height: 45px; /* Kutunun yüksekliği */
        display: flex; /* İçindeki resmi ortalamak için */
        align-items: center;
        justify-content: center;
        overflow: hidden; /* Taşmaları engeller (Yuvarlak pencere etkisi) */
        border-radius: 50%; /* Kutuyu tam yuvarlak yapar */
        background-color: #fff; /* Fotoğraf yüklenene kadar beyaz zemin */
        border: 2px solid rgba(255, 255, 255, 0.2); /* Şık bir çerçeve */
    }

    /* Resmin kendisini kutuya göre ölçeklendiriyoruz */
    .sidebar-profile-img {
        width: 100%; /* Kutunun genişliğine yayıl */
        height: 100%; /* Kutunun yüksekliğine yayıl */
        object-fit: cover; /* Resmi ezmeden, pencereyi dolduracak şekilde kırp */
        display: block;
    }

    /* Yazıların resmin yanında düzgün durması için */
    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 12px; /* Resim ile yazı arasındaki boşluk */
        padding: 10px 15px;
    }
</style>