            <a href="/Brand/BrandList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-copyright"></i></span>
                <span class="link-text">Marka Yönetimi</span>
            </a>

            <a href="/Car/CarList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-car"></i></span>
                <span class="link-text">Araba Yönetimi</span>
            </a>

            <a href="/CarModel/CarModelList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-car-side"></i></span>
                <span class="link-text">Araba Modeli Yönetimi</span>
            </a>

            <a href="/Comment/CommentList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-comments"></i></span>
                <span class="link-text">Yorum Yönetimi</span>
            </a>

            <a href="/Features/FeaturesList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
                <span class="link-text">Özellikler Yönetimi</span>
            </a>

            <a href="/Footer/FooterList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-window-maximize"></i></span>
                <span class="link-text">Alt Kısım Yönetimi</span>
            </a>

            <a href="/Questions/QuestionsList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-circle-question"></i></span>
                <span class="link-text">Soru Yönetimi</span>
            </a>

            <a href="/Reservation/ReservationList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-calendar-check"></i></span>
                <span class="link-text">Rezervasyon Yönetimi</span>
            </a>

            <a href="/Step/StepList/" class="nav-link">
                <span class="nav-icon"><i class="fa-solid fa-list-ol"></i></span>
                <span class="link-text">Adım Yönetimi</span>
            </a>
        </nav>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebarMobile()"></div>

    <div class="main-wrapper" id="mainWrapper">

        <nav class="navbar-top" id="navbarTop">
            <button class="toggle-btn" id="toggleBtn" onclick="toggleSidebar()">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="navbar-breadcrumb d-none d-sm-block">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/_Layout/Index/">Siteye Git</a></li>

                </ol>
            </div>
