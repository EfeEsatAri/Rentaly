@model List<ResultFeaturesDto>
@{
    ViewData["Title"] = "Özellik Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="fas fa-star me-2"></i>Sistem Özellikleri</h5>
            <a href="/Features/CreateFeatures/" class="btn btn-light btn-sm fw-bold shadow-sm">
                <i class="fas fa-plus me-1"></i>Yeni Özellik Ekle
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%">#</th>
                            <th style="width: 10%">İkon</th>
                            <th style="width: 25%">Başlık</th>
                            <th style="width: 40%">Açıklama</th>
                            <th style="width: 20%" class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td>
                                    <div class="bg-light d-flex align-items-center justify-content-center rounded" style="width: 40px; height: 40px;">
                                        <i class="@item.Icon text-primary fs-5"></i>
                                    </div>
                                </td>
                                <td><span class="fw-bold">@item.Title</span></td>
                                <td><small class="text-muted">@item.Description</small></td>
                                <td class="text-center">
                                    <a href="/Features/UpdateFeatures/@item.FeaturesId" class="btn btn-outline-warning btn-sm me-1">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                    <a href="/Features/DeleteFeatures/@item.FeaturesId" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu özelliği silmek istediğinize emin misiniz?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>