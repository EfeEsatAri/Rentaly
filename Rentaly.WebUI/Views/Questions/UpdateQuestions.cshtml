@model UpdateQuestionsDto
@{
    ViewData["Title"] = "Soruyu Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning py-3">
                    <h5 class="mb-0 text-dark"><i class="fas fa-sync-alt me-2"></i>Soru İçeriğini Güncelle</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="QuestionsId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark">Soru Metni</label>
                            <input type="text" asp-for="Title" class="form-control border-primary" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark">Detaylı Cevap</label>
                            <textarea asp-for="Description" rows="8" class="form-control border-primary"></textarea>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a href="/Questions/QuestionsList" class="btn btn-light border px-4">Geri Dön</a>
                            <button type="submit" class="btn btn-warning px-5 fw-bold shadow-sm">Güncelleme Tamamla</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>