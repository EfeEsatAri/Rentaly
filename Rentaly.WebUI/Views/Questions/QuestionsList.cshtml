@model List<ResultQuestionsDto>
@{
	ViewData["Title"] = "Sıkça Sorulan Sorular";
	Layout = "~/Views/AdminLayout/Index.cshtml";
	int count = 0;
}

<div class="container-fluid py-4">
	<div class="card shadow-sm border-0">
		<div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center py-3">
			<h5 class="mb-0"><i class="fas fa-question-circle me-2"></i>Soru & Cevap Yönetimi</h5>
			<a href="/Questions/CreateQuestions/" class="btn btn-light btn-sm fw-bold">
				<i class="fas fa-plus-circle me-1"></i>Yeni Soru Ekle
			</a>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<table class="table table-hover align-middle">
					<thead class="table-light">
						<tr>
							<th style="width: 5%">#</th>
							<th style="width: 30%">Soru Başlığı</th>
							<th style="width: 45%">Cevap / Açıklama</th>
							<th style="width: 20%" class="text-center">İşlemler</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							count++;
							<tr>
								<td>@count</td>
								<td><span class="fw-bold text-dark">@item.Title</span></td>
								<td>
									<div class="text-muted small text-truncate" style="max-width: 400px;">
										@item.Description
									</div>
								</td>
								<td class="text-center">
									<div class="btn-group">
										<a href="/Questions/UpdateQuestions/@item.QuestionsId" class="btn btn-outline-primary btn-sm">
											<i class="fas fa-edit"></i> Düzenle
										</a>
										<a href="/Questions/DeleteQuestions/@item.QuestionsId" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu soruyu silmek istediğinize emin misiniz?')">
											<i class="fas fa-trash"></i>
										</a>
									</div>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>

		</div>
	</div>
</div>
