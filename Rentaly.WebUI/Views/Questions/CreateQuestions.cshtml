@model CreateQuestionsDto
@{
    ViewData["Title"] = "Yeni Soru Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-plus me-2"></i>Yeni Soru & Cevap Oluştur</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Soru Başlığı</label>
                            <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Kiralama koşulları nelerdir?" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cevap (Açıklama)</label>
                            <textarea asp-for="Description" rows="6" class="form-control" placeholder="Soruya verilecek detaylı cevap..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a href="/Questions/QuestionsList" class="btn btn-outline-secondary px-4">İptal</a>
                            <button type="submit" class="btn btn-success px-5 shadow-sm">Soruyu Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>