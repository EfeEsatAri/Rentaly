@model List<Rentaly.EntityLayer.Entities.Reservation>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h3 class="fw-bold text-dark">Hoş Geldiniz, Efe Esat Bey!</h3>
            <p class="text-muted small">Sistemin genel durumu ve son aktiviteler aşağıda listelenmiştir.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100" style="background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);">
                <div class="d-flex justify-content-between align-items-center text-white">
                    <div>
                        <div class="small opacity-75">Toplam Araç</div>
                        <div class="h2 fw-bold mb-0">@ViewBag.TotalCars</div>
                    </div>
                    <i class="fa-solid fa-car fa-3x opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                <div class="d-flex justify-content-between align-items-center text-white">
                    <div>
                        <div class="small opacity-75">Müsait Araçlar</div>
                        <div class="h2 fw-bold mb-0">@ViewBag.AvailableCars</div>
                    </div>
                    <i class="fa-solid fa-check-double fa-3x opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100" style="background: linear-gradient(135deg, #ff9966 0%, #ff5e62 100%);">
                <div class="d-flex justify-content-between align-items-center text-white">
                    <div>
                        <div class="small opacity-75">Bekleyen Rezervasyon</div>
                        <div class="h2 fw-bold mb-0">@ViewBag.PendingReservations</div>
                    </div>
                    <i class="fa-solid fa-hourglass-half fa-3x opacity-25"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 h-100" style="background: linear-gradient(135deg, #373b44 0%, #4286f4 100%);">
                <div class="d-flex justify-content-between align-items-center text-white">
                    <div>
                        <div class="small opacity-75">Hizmet Noktası</div>
                        <div class="h2 fw-bold mb-0">@ViewBag.TotalBranches</div>
                    </div>
                    <i class="fa-solid fa-map-location-dot fa-3x opacity-25"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-list me-2"></i>Son Rezervasyonlar</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="ps-3">Müşteri</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-3">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold">@item.Name @item.Surname</div>
                                            <div class="small text-muted">@item.Email</div>
                                        </td>
                                        <td class="small">@item.ReservationDate.ToShortDateString()</td>
                                        <td>
                                            <span class="badge rounded-pill bg-soft-primary text-primary px-3">@item.Status</span>
                                        </td>
                                        <td class="text-end pe-3">
                                            <a href="/Reservation/ReservationList" class="btn btn-sm btn-outline-secondary border-0"><i class="fa-solid fa-eye"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-bolt me-2"></i>Sistem Analizi</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="small fw-bold">Araç Doluluk Oranı</label>
                        @{
                            double occupancy = (double)(ViewBag.TotalCars - ViewBag.AvailableCars) / ViewBag.TotalCars * 100;
                        }
                        <div class="progress mt-2" style="height: 10px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: @occupancy.ToString("0")%"></div>
                        </div>
                        <small class="text-muted">Şu an filonun %@occupancy.ToString("0")'ı kullanımda.</small>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="/Car/CarList" class="btn btn-light text-start border-0 py-2 px-3 rounded-3 shadow-sm">
                            <i class="fa-solid fa-plus-circle me-2 text-success"></i> Yeni Araç Ekle
                        </a>
                        <a href="/Reservation/ReservationList" class="btn btn-light text-start border-0 py-2 px-3 rounded-3 shadow-sm">
                            <i class="fa-solid fa-clock me-2 text-warning"></i> Onay Bekleyenler
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: #e7f1ff;
    }

    .card {
        transition: transform 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }
</style>