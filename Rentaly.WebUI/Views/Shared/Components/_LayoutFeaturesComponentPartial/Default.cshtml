@model List<Rentaly.EntityLayer.Entities.Features>

<section aria-label="section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 offset-lg-3 text-center">
                <h2>Özelliklerimiz</h2>
                <p>Konfor, güvenlik ve kişiselleştirme dünyasını keşfedin; unutulmaz maceraların ve kusursuz mobilite çözümlerinin önünü açın.</p>
                <div class="spacer-20"></div>
            </div>

            <div class="clearfix"></div>

            <div class="col-lg-3">
                @foreach (var item in Model.Take(2))
                {
                    <div class="box-icon s2 p-small mb20 wow fadeInLeft" data-wow-delay=".5s">
                        <i class="@item.Icon"></i>
                        <div class="d-inner">
                            <h4>@item.Title</h4>
                            @item.Description
                        </div>
                    </div>
                }
            </div>

             <div class="col-lg-6 text-center">
                <img src="~/rentaly/images/misc/car.png" alt="Araba" class="img-fluid wow fadeInUp">
            </div>

            <div class="col-lg-3">
                @foreach (var item in Model.Skip(2).Take(2))
                {
                    <div class="box-icon s2 d-invert p-small mb20 wow fadeInRight" data-wow-delay=".5s">
                        <i class="@item.Icon"></i>
                        <div class="d-inner">
                            <h4>@item.Title</h4>
                            @item.Description
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</section>