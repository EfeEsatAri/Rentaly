<div class="col-lg-12">
    <div class="spacer-single sm-hide"></div>
    <div class="p-4 rounded-3 shadow-soft" data-bgcolor="#ffffff">
        <form name="contactForm" id='contact_form' method="get" action="/_Layout/CarList">
            <div id="step-1" class="row">

                <div class="col-lg-6 mb30">
                    <h5 class="text-dark">Hangi Şanzıman Tipi?</h5>
                    <div class="de_form de_radio row g-3">
                        <div class="radio-img col-lg-4 col-sm-4 col-6">
                            <input id="radio-1a" name="transmission" type="radio" value="" checked="checked">
                            <label for="radio-1a" class="text-dark"><img src="~/rentaly/images/select-form/car.png" alt="">Hepsi</label>
                        </div>
                        <div class="radio-img col-lg-4 col-sm-4 col-6">
                            <input id="radio-1b" name="transmission" type="radio" value="false">
                            <label for="radio-1b" class="text-dark"><img src="~/rentaly/images/select-form/van.png" alt="">Manuel</label>
                        </div>
                        <div class="radio-img col-lg-4 col-sm-4 col-6">
                            <input id="radio-1c" name="transmission" type="radio" value="true">
                            <label for="radio-1c" class="text-dark"><img src="~/rentaly/images/select-form/minibus.png" alt="">Otomatik</label>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="row">
                        <div class="col-lg-6 mb20">
                            <h5 class="text-dark">Marka Seçin</h5>
                            <select name="brandId" class="form-control">
                                <option value="">Tüm Markalar</option>
                                @if (ViewBag.Brands != null)
                                {
                                    foreach (var brand in ViewBag.Brands)
                                    {
                                        <option value="@brand.BrandId">@brand.BrandName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-lg-6 mb20">
                            <h5 class="text-dark">Yakıt Tipi</h5>
                            <select name="fuelType" class="form-control">
                                <option value="">Tüm Yakıtlar</option>
                                <option value="Benzin">Benzin</option>
                                <option value="Dizel">Dizel</option>
                                <option value="Elektrikli">Elektrikli</option>
                                <option value="Hibrit">Hibrit</option>
                            </select>
                        </div>

                        <div class="col-lg-12 mb20">
                            <h5 class="text-dark">Teslim Alma Şubesi</h5>
                            <select name="branchId" class="form-control">
                                <option value="">Tüm Şubeler</option>
                                @if (ViewBag.Branches != null)
                                {
                                    foreach (var branch in ViewBag.Branches)
                                    {
                                        <option value="@branch.BranchId">@branch.BranchName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-lg-12 row mb20">
                    <div class="col-lg-3">
                        <h5 class="text-dark">Min Fiyat (₺)</h5>
                        <input type="number" name="minPrice" class="form-control" placeholder="0">
                    </div>
                    <div class="col-lg-3">
                        <h5 class="text-dark">Max Fiyat (₺)</h5>
                        <input type="number" name="maxPrice" class="form-control" placeholder="10000">
                    </div>
                    <div class="col-lg-6 text-end align-self-end">
                        <button type="submit" class="btn-main rounded-pill px-5">
                            <i class="fa fa-search me-2"></i>Aracı Bul
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>