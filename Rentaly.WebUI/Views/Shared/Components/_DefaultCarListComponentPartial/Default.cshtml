@model List<CarListViewModel>

<div class="row">
	@foreach (var item in Model)
	{
		@* Sadece görseli olan araçları gösterelim *@
		if (!string.IsNullOrEmpty(item.ImageUrl))
		{
			<div class="col-xl-4 col-lg-6 mb-4 d-flex align-items-stretch">
				@* align-items-stretch kart boylarını eşitler *@
				<div class="de-item mb30 w-100 d-flex flex-column" style="border: 1px solid #eee; border-radius: 10px; overflow: hidden; background: #fff;">

					@* Görsel Alanı *@
					<div class="d-img" style="height: 200px; overflow: hidden;">
						<img src="@item.ImageUrl" class="img-fluid w-100 h-100" style="object-fit: cover;" alt="@item.BrandName">
					</div>

					@* İçerik Alanı *@
					<div class="d-info p-3 d-flex flex-column flex-grow-1">
						<div class="d-text flex-grow-1">
							@* Başlık: Çok uzunsa keser *@
							<h4 style="font-size: 18px; margin-bottom: 10px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
								@item.BrandName @item.ModelName
							</h4>

							@* İkon Grubu: Sabit yükseklik vererek kaymayı önlüyoruz *@
							<div class="d-atr-group" style="min-height: 50px; font-size: 13px;">
								<span class="d-atr"><img src="~/rentaly/images/icons/1-green.svg" style="width:16px;" alt=""> @item.SeatCount</span>
								<span class="d-atr"><img src="~/rentaly/images/icons/2-green.svg" style="width:16px;" alt=""> @item.LuggageCount</span>
								<span class="d-atr"><img src="~/rentaly/images/icons/3-green.svg" style="width:16px;" alt=""> @item.FuelType</span>
								<span class="d-atr">
									<img src="~/rentaly/images/icons/4-green.svg" style="width:16px;" alt="">
									@(item.CategoryName.Length > 20 ? item.CategoryName.Substring(0, 18) + "..." : item.CategoryName)
								</span>
							</div>

							<hr style="opacity: .1; margin: 15px 0;" />

							@* Fiyat ve Depozito Alanı: flex-shrink-0 ile her zaman en altta kalmasını sağlıyoruz *@
							<div class="d-price-container mb-3" style="display: flex; justify-content: space-between;">
								<div>
									<div style="font-size: 11px; color: #888; text-transform: uppercase;">Günlük</div>
									<strong style="font-size: 17px; color: #1ecb15;">@item.DailyPrice.ToString("C0")</strong>
								</div>
								<div class="text-end">
									<div style="font-size: 11px; color: #888; text-transform: uppercase;">Depozito</div>
									<strong style="font-size: 15px; color: #333;">@item.DepositAmount.ToString("C0")</strong>
								</div>
							</div>
						</div>

						@* Buton *@
						<div class="mt-auto">
							<a class="btn-main w-100 text-center py-2" style="border-radius: 5px;" asp-controller="_Layout" asp-action="CarDetails" asp-route-id="@item.CarId">
								Hemen Kirala
							</a>
						</div>
					</div>
				</div>
			</div>
		}
	}
</div>




<div class="row">
	<div class="col-md-12 text-center">
		<ul class="pagination justify-content-center">

			@* Geri Butonu *@
			@if (ViewBag.CurrentPage > 1)
			{
				<li class="page-item">
					<a class="page-link" href="@Url.Action("CarList", new { page = ViewBag.CurrentPage - 1 })">
						<i class="fa fa-chevron-left"></i>
					</a>
				</li>
			}

			@* Sayfa Numaraları *@
			@for (int i = 1; i <= ViewBag.TotalPages; i++)
			{
				<li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
					<a class="page-link" href="@Url.Action("CarList", new { page = i })">@i</a>
				</li>
			}

			@* İleri Butonu *@
			@if (ViewBag.CurrentPage < ViewBag.TotalPages)
			{
				<li class="page-item">
					<a class="page-link" href="@Url.Action("CarList", new { page = ViewBag.CurrentPage + 1 })">
						<i class="fa fa-chevron-right"></i>
					</a>
				</li>
			}
		</ul>
	</div>
</div>