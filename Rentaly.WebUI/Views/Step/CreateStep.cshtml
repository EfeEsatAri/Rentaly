@model CreateStepDto

@{
    ViewData["Title"] = "Kiralama Adımları";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="container py-5">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 600px;">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4">Yeni Adım Ekle</h5>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Adım Başlığı</label>
                    <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Aracınızı Seçin" />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Kısa Açıklama</label>
                    <textarea asp-for="Description" rows="4" class="form-control" placeholder="Müşteriye ne yapması gerektiğini anlatın..."></textarea>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Kaydet ve Yayınla</button>
                </div>
            </form>
        </div>
    </div>
</div>