@model List<ResultStepDto>
@{
    ViewData["Title"] = "Kiralama Adımları";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-primary">
                <i class="fas fa-shoe-prints me-2"></i>Kiralama Süreç Adımları
            </h5>
            <a href="/Step/CreateStep/" class="btn btn-primary btn-sm rounded-pill px-3">
                <i class="fas fa-plus me-1"></i>Yeni Adım Ekle
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Sıra</th>
                            <th>Aşama Başlığı</th>
                            <th>Açıklama Detayı</th>
                            <th class="text-center" style="width: 150px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td class="ps-4">
                                    <div class="step-number bg-soft-primary text-primary fw-bold">
                                        @count
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark">@item.Title</div>
                                </td>
                                <td>
                                    <p class="text-muted small mb-0" style="max-width: 500px;">
                                        @item.Description
                                    </p>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm rounded">
                                        <a href="/Step/UpdateStep/@item.StepId" class="btn btn-white btn-sm border-end" title="Düzenle">
                                            <i class="fas fa-pencil-alt text-warning"></i>
                                        </a>
                                        <a href="/Step/DeleteStep/@item.StepId" class="btn btn-white btn-sm" onclick="return confirm('Bu süreci silmek istediğinize emin misiniz?')" title="Sil">
                                            <i class="fas fa-trash text-danger"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light border-top-0 py-3 text-center">
            <small class="text-muted">Bu adımlar ana sayfanızda "Nasıl Kiralayabilirim?" bölümünde sırasıyla görünecektir.</small>
        </div>
    </div>
</div>

<style>
    .step-number {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .bg-soft-primary {
        background-color: #eef2ff;
    }

    .table-hover tbody tr:hover {
        background-color: #fcfcfd;
    }

    .btn-white {
        background: #fff;
        border: 1px solid #eee;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }
</style>