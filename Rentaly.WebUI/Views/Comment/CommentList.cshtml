@model List<ResultCommentDto>
@{
    ViewData["Title"] = "Yorum Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-comments me-2"></i>Müşteri Yorumları</h5>
            <a href="/Comment/CreateComment/" class="btn btn-outline-light btn-sm">
                <i class="fas fa-plus me-1"></i>Yeni Yorum Ekle
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Profil</th>
                            <th>Ad Soyad / Başlık</th>
                            <th>Yorum Özeti</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td>
                                    <img src="@item.ImageUrl" class="rounded-circle shadow-sm" width="45" height="45" style="object-fit: cover;" alt="user" />
                                </td>
                                <td>
                                    <div class="fw-bold">@item.NameSurname</div>
                                    <small class="text-muted">@item.Title</small>
                                </td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width: 250px;">
                                        @item.Description
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="/Comment/UpdateComment/@item.CommentId" class="btn btn-info btn-sm text-white">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/Comment/DeleteComment/@item.CommentId" class="btn btn-danger btn-sm" onclick="return confirm('Yorumu silmek istediğinize emin misiniz?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>