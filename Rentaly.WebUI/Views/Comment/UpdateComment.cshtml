@model UpdateCommentDto
@{
    ViewData["Title"] = "Yorum Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm mx-auto" style="max-width: 800px;">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Yorumu Güncelle</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="CommentId" />

                <div class="text-center mb-4">
                    <img src="@Model.ImageUrl" class="rounded-circle img-thumbnail" width="100" height="100" style="object-fit: cover;" />
                    <p class="text-muted mt-2">Mevcut Görsel</p>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ad Soyad</label>
                        <input type="text" asp-for="NameSurname" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Başlık</label>
                        <input type="text" asp-for="Title" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Görsel URL</label>
                    <input type="text" asp-for="ImageUrl" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Yorum</label>
                    <textarea asp-for="Description" rows="5" class="form-control"></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="/Comment/CommentList" class="btn btn-secondary">Listeye Dön</a>
                    <button type="submit" class="btn btn-info text-white px-4">Değişiklikleri Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>