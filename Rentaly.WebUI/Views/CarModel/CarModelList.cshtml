@model List<ResultCarModelDto>
@{
    ViewData["Title"] = "Araç Modelleri";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-car me-2"></i>Araç Model Listesi</h5>
            <a href="/CarModel/CreateCarModel/" class="btn btn-light btn-sm fw-bold">
                <i class="fas fa-plus-circle me-1"></i>Yeni Model Ekle
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">#</th>
                            <th>Model Adı</th>
                            <th class="text-center" style="width: 200px;">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td>
                                        <span class="fw-bold">@item.ModelName</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a href="/CarModel/UpdateCarModel/@item.CarModelId" class="btn btn-outline-warning btn-sm" title="Güncelle">
                                                <i class="fas fa-edit"></i> Güncelle
                                            </a>
                                            <a href="/CarModel/DeleteCarModel/@item.CarModelId" class="btn btn-outline-danger btn-sm" title="Sil" onclick="return confirm('Bu modeli silmek istediğinize emin misiniz?')">
                                                <i class="fas fa-trash"></i> Sil
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    <i class="fas fa-info-circle me-1"></i> Listelenecek araç modeli bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>