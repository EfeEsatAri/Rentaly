@model List<ResultReservationDto>
@{
    ViewData["Title"] = "Rezervasyon Paneli";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <!-- Üst İstatistik Kartları -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4 shadow-sm border-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Toplam Rezervasyon</div>
                        <div class="h3 mb-0">@Model.Count</div>
                    </div>
                    <i class="fas fa-list-ul fa-2x text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-warning text-white mb-4 shadow-sm border-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Bekleyen Onay</div>
                        <div class="h3 mb-0">@Model.Count(x => x.Status == "Beklemede")</div>
                    </div>
                    <i class="fas fa-clock fa-2x text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4 shadow-sm border-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Doğrulanmış Müşteri</div>
                        <div class="h3 mb-0">@Model.Count(x => x.IsEmailVerified)</div>
                    </div>
                    <i class="fas fa-user-check fa-2x text-white-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4 shadow-sm border-0">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">İptal Edilenler</div>
                        <div class="h3 mb-0">@Model.Count(x => x.Status == "İptal Edildi")</div>
                    </div>
                    <i class="fas fa-ban fa-2x text-white-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Rezervasyon Tablosu -->
    <div class="card shadow-sm border-0 mt-2">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom">
            <h5 class="mb-0 text-dark fw-bold"><i class="fas fa-table me-2 text-primary"></i>Güncel Rezervasyon Akışı</h5>
            <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm"><i class="fas fa-download me-1"></i> Excel'e Aktar</button>
                <button class="btn btn-outline-secondary btn-sm"><i class="fas fa-print me-1"></i> Yazdır</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted text-uppercase small">
                        <tr>
                            <th class="ps-4">Müşteri Detayları</th>
                            <th>Araç & Kod</th>
                            <th>Doğrulama</th>
                            <th>Rezervasyon Tarihi</th>
                            <th>Durum</th>
                            <th class="text-end pe-4">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-soft-primary text-primary fw-bold me-3">
                                            @item.Name.Substring(0, 1)@item.Surname.Substring(0, 1)
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.Name @item.Surname</div>
                                            <div class="text-muted small">@item.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="badge rounded-pill bg-light text-dark border fw-normal mb-1">ID: #@item.CarId</div>
                                    <div class="small text-primary fw-bold">Kod: @item.VerificationCode</div>
                                </td>
                                <td>
                                    @if (item.IsEmailVerified)
                                    {
                                        <span class="text-success small fw-bold"><i class="fas fa-check-circle me-1"></i> Onaylı</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small fw-bold"><i class="fas fa-exclamation-triangle me-1"></i> Bekliyor</span>
                                    }
                                </td>
                                <td>
                                    <div class="small fw-bold text-dark">@item.ReservationDate.ToString("dd MMMM yyyy")</div>
                                    <div class="text-muted smaller">@item.ReservationDate.ToShortTimeString()</div>
                                </td>
                                <td>
                                    @{
                                        string badgeClass = item.Status switch
                                        {
                                            "Onaylandı" => "bg-success",
                                            "Beklemede" => "bg-warning text-dark",
                                            "İptal Edildi" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass shadow-none px-3">@item.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle border shadow-sm" type="button" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li><a class="dropdown-item text-primary" href="#"><i class="fas fa-check me-2"></i>Onayla</a></li>
                                            <li><a class="dropdown-item text-danger" href="#"><i class="fas fa-times me-2"></i>İptal Et</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item" href="#"><i class="fas fa-eye me-2"></i>Detayları Gör</a></li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3 border-top text-muted small">
            Toplam <strong>@Model.Count</strong> kayıt içerisinden aktif rezervasyonlar listeleniyor.
        </div>
    </div>
</div>

<style>
    /* Daha profesyonel görünüm için ekstra CSS */
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }

    .bg-soft-primary {
        background-color: #e7f1ff;
    }

    .smaller {
        font-size: 0.75rem;
    }

    .table thead th {
        border-top: none;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .card {
        border-radius: 12px;
    }

    .badge {
        font-weight: 500;
        letter-spacing: 0.3px;
    }
</style>