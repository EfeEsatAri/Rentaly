@model UpdateReservationDto
@{
    ViewData["Title"] = "Rezervasyon Güncelle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm mx-auto" style="max-width: 900px;">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Rezervasyon Bilgilerini Düzenle</h5>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <input type="hidden" asp-for="ReservationId" />
                <input type="hidden" asp-for="ReservationDate" />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Ad</label>
                        <input type="text" asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Soyad</label>
                        <input type="text" asp-for="Surname" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-danger">Doğrulama Kodu</label>
                        <input type="text" asp-for="VerificationCode" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">E-Posta</label>
                        <input type="email" asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Durum</label>
                        <select asp-for="Status" class="form-select border-info">
                            <option value="Beklemede">Beklemede</option>
                            <option value="Onaylandı">Onaylandı</option>
                            <option value="İptal Edildi">İptal Edildi</option>
                        </select>
                    </div>

                    <div class="col-12 mt-4">
                        <div class="p-3 bg-light rounded border d-flex justify-content-between align-items-center">
                            <span>E-posta doğrulama durumu:</span>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsEmailVerified">
                                <label class="form-check-label fw-bold">@(Model.IsEmailVerified ? "Doğrulandı" : "Doğrulanmadı")</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4 border-top pt-3">
                    <a href="/Reservation/ReservationList" class="btn btn-outline-secondary px-4">Geri Dön</a>
                    <button type="submit" class="btn btn-info text-white px-5 shadow">Bilgileri Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>